# ============================================
# Production — для сервера (DEPLOY_PATH, например /root/mobilka)
# ============================================
# Скопируйте на сервер как .env и подставьте реальные значения.
# НЕ коммитьте файл .env и не добавляйте его в репозиторий.

# Образ backend из GitHub Container Registry (замените YOUR_GITHUB_USERNAME на владельца репо)
BACKEND_IMAGE=ghcr.io/paradniknikita-debug/mobilka-backend:latest

# PostgreSQL
POSTGRES_DB=lepm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=146080b6

# Строка подключения к БД (хост postgres — имя сервиса в docker-compose)
# В пароле замените спецсимволы на URL-кодировку или используйте простой пароль
DATABASE_URL=postgresql://postgres:146080b6@postgres:5432/lepm_db

REDIS_URL=redis://redis:6379

# Секрет для JWT (сгенерируйте: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=Lfo6ukji3upsUyYiZx883G9wtOmgqCHe3LR1otz3_Tc

ENVIRONMENT=production

# Разрешённые origins для CORS (через запятую или * для теста)
#CORS_ORIGINS=https://ваш-домен.ru
# CORS_ORIGINS=*

TZ=Europe/Moscow

# MinIO (docker-compose.prod: сервис minio). Вложения опор хранятся в bucket через S3 API.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=смените_на_случайный_пароль
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_MEDIA=lepm-media
S3_REGION=us-east-1
