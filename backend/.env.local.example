# ============================================
# Локальная разработка и тесты (backend)
# ============================================
# Скопируйте в .env: cp .env.local.example .env
# Либо переименуйте и подставьте свои значения.

# База данных (локальный PostgreSQL или контейнер на 5433)
DATABASE_URL=postgresql://postgres:dragon167@localhost:5433/lepm_db

# Для backend в Docker (docker-compose) используйте хост postgres:
# DATABASE_URL=postgresql://postgres:dragon167@postgres:5432/lepm_db

# JWT — для разработки можно любой длинный ключ
SECRET_KEY=CHANGE_ME_SECRET_KEY_DEV_MIN_32_CHARS

# Redis
REDIS_URL=redis://localhost:6379
# В Docker: REDIS_URL=redis://redis:6379

# Окружение: development — добавляет CORS для localhost:4200, :53380, :8000
ENVIRONMENT=development

# CORS для прода не нужен; для development задавать не обязательно
# CORS_ORIGINS=

# --- MinIO / S3 (вложения карточки опоры) ---
# В ENVIRONMENT=development backend сам подставляет http://127.0.0.1:9000 + minioadmin,
# если S3_ENDPOINT_URL не задан (удобно при `docker compose up minio` и backend на хосте).
# Явно задать endpoint (например backend в Docker, MinIO на хосте — не ваш случай):
# S3_ENDPOINT_URL=http://127.0.0.1:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET_MEDIA=lepm-media
# Полностью отключить автоподключение и писать только в uploads/pole_attachments:
# DISABLE_LOCAL_MINIO=1
