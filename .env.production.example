# ============================================
# Production — docker-compose.prod.yml (корень проекта или сервер)
# ============================================
# Скопируйте в .env и подставьте реальные значения.
# На сервере: скопируйте server-deploy-files/env.example в .env.
# НЕ коммитьте .env.

# Образ backend (на сервере — из GHCR; локально можно собрать свой)
BACKEND_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/mobilka-backend:latest

POSTGRES_DB=lepm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<надёжный пароль>

DATABASE_URL=postgresql://postgres:PASSWORD@postgres:5432/lepm_db
REDIS_URL=redis://redis:6379
SECRET_KEY=<сгенерируйте длинный ключ>
ENVIRONMENT=production
CORS_ORIGINS=https://your-domain.com
TZ=Europe/Moscow
